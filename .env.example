# ===== App =====
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# ===== Postgres =====
POSTGRES_USER=avisador
POSTGRES_PASSWORD=changeme
POSTGRES_DB=avisador
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# SQLAlchemy async URL (asyncpg)
DATABASE_URL=postgresql+asyncpg://avisador:changeme@localhost:5432/avisador

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ===== ESPN Core API (D9) =====
ESPN_BASE_URL=https://sports.core.api.espn.com/v2
ESPN_LEAGUE=ufc
ESPN_TIMEOUT_SECONDS=10
ESPN_MAX_RETRIES=5
ESPN_CIRCUIT_BREAKER_FAILS=5
ESPN_CIRCUIT_BREAKER_OPEN_SECONDS=60
# Caché de atletas (nombre+foto), 7 días por defecto
ATHLETE_CACHE_TTL_SECONDS=604800

# ===== Polling & alertas (D15-D23) =====
# Scheduler in-process (D31): poner false para desactivar el poller (p.ej. tests)
SCHEDULER_ENABLED=true
LEAD_MINUTES_DEFAULT=15
BUFFER_INTERCOMBATE_SECONDS=600
ALERT_IDEMPOTENCY_TTL_SECONDS=7200
POLL_DEFAULT_SECONDS=60
POLL_PREV_IN_ADVANCED_SECONDS=10
POLL_PREV_POST_SECONDS=5
DEFAULT_TIMEZONE=Europe/Madrid

# ===== Notifier (D23, D30) =====
# Si las 3 variables tienen valor -> TwilioNotifier (llamadas reales).
# Si falta alguna -> DummyNotifier (solo log). Activable sin tocar codigo.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ===== Firebase Cloud Messaging (Fase 7a) =====
# Service account key JSON para firebase-admin (notifiers/fcm.py).
# Opcion A: ruta al fichero .firebase-service-account.json (ignorado en git).
FCM_CREDENTIALS_PATH=.firebase-service-account.json
# Opcion B: pegar el contenido del JSON en una sola linea (para Railway/deploy).
# Si ambas estan set, FCM_CREDENTIALS_JSON tiene prioridad.
# FCM_CREDENTIALS_JSON=
# ID del proyecto Firebase (por si firebase-admin no lo saca del JSON).
# FCM_PROJECT_ID=despertarme-73d00

# ===== Auth JWT (Fase 3) =====
# En produccion (APP_ENV=production) es OBLIGATORIO cambiarlo:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-please
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60